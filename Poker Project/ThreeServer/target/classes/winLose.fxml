<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="project3.client.WinLoseController"
      alignment="CENTER" spacing="20" style="-fx-padding: 30;">
    
    <Label fx:id="msgLabel" text="Game Result" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    <Label fx:id="amtLabel" text="Amount Won/Lost" style="-fx-font-size: 16px;"/>
    
    <HBox alignment="CENTER" spacing="20">
        <Button text="Play Again" onAction="#handlePlayAgain"/>
        <Button text="Exit Game" onAction="#handleExit"/>
    </HBox>
</VBox>