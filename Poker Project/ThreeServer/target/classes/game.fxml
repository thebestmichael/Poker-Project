<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="rootPane" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="project3.client.GameController"
            style="-fx-background-color: green; -fx-padding: 10;">
    
    <top>
        <MenuBar>
            <Menu text="Options">
                <MenuItem text="Fresh Start" onAction="#handleFreshStart"/>
                <MenuItem text="New Look" onAction="#handleNewLook"/>
                <MenuItem text="Exit" onAction="#handleExit"/>
            </Menu>
        </MenuBar>
    </top>
    
    <center>
        <VBox alignment="CENTER" spacing="20">
            <Label text="Dealer's Hand" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
            <HBox alignment="CENTER" spacing="10">
                <Label fx:id="dCard1" style="-fx-background-color: white; -fx-padding: 20;" text="?"/>
                <Label fx:id="dCard2" style="-fx-background-color: white; -fx-padding: 20;" text="?"/>
                <Label fx:id="dCard3" style="-fx-background-color: white; -fx-padding: 20;" text="?"/>
            </HBox>
            
            <Label text="Player's Hand" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
            <HBox alignment="CENTER" spacing="10">
                <Label fx:id="pCard1" style="-fx-background-color: white; -fx-padding: 20;" text="?"/>
                <Label fx:id="pCard2" style="-fx-background-color: white; -fx-padding: 20;" text="?"/>
                <Label fx:id="pCard3" style="-fx-background-color: white; -fx-padding: 20;" text="?"/>
            </HBox>
            
            <HBox alignment="CENTER" spacing="20">
                <Button fx:id="playBtn" text="PLAY" onAction="#handlePlay" disable="true" prefWidth="100"/>
                <Button fx:id="foldBtn" text="FOLD" onAction="#handleFold" disable="true" prefWidth="100"/>
            </HBox>
        </VBox>
    </center>
    
    <left>
        <VBox spacing="15" style="-fx-background-color: rgba(255,255,255,0.8); -fx-padding: 15;">
            <Label fx:id="totalWinnings" text="Total Winnings: $0"/>
            <Separator/>
            <Label text="Ante Bet ($5-$25):"/>
            <TextField fx:id="anteField" text="10"/>
            <Label text="Pair Plus (Optional):"/>
            <TextField fx:id="ppField" text="0"/>
            <Button fx:id="dealBtn" text="DEAL" onAction="#handleDeal" maxWidth="Infinity"/>
        </VBox>
    </left>
    
    <bottom>
        <TextArea fx:id="gameLog" prefHeight="100" editable="false"/>
    </bottom>
    
</BorderPane>