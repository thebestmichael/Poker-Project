<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="project3.client.GameController">
   <top>
      <MenuBar BorderPane.alignment="CENTER">
        <menus>
          <Menu mnemonicParsing="false" text="Options">
            <items>
              <MenuItem fx:id="freshStartMenuItem" mnemonicParsing="false" onAction="#handleFreshStart" text="Fresh Start" />
              <MenuItem fx:id="newLookMenuItem" mnemonicParsing="false" onAction="#handleNewLook" text="New Look" />
              <MenuItem fx:id="exitMenuItem" mnemonicParsing="false" onAction="#handleExit" text="Exit" />
            </items>
          </Menu>
        </menus>
      </MenuBar>
   </top>
   <center>
      <VBox alignment="TOP_CENTER" spacing="20.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Dealer's Hand" />
            <HBox fx:id="dealerCardBox" alignment="CENTER" prefHeight="120.0" prefWidth="200.0" spacing="10.0" style="-fx-background-color: #ecf0f1; -fx-background-radius: 10;" />
            
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Your Hand" />
            <HBox fx:id="playerCardBox" alignment="CENTER" prefHeight="120.0" prefWidth="200.0" spacing="10.0" style="-fx-background-color: #ecf0f1; -fx-background-radius: 10;" />
            
            <Label fx:id="totalWinningsLabel" style="-fx-font-size: 20px; -fx-text-fill: #27ae60;" text="Total Winnings: $0" />
            
            <TextArea fx:id="gameLogArea" editable="false" prefHeight="150.0" prefWidth="200.0" wrapText="true" />
         </children>
      </VBox>
   </center>
   <right>
      <VBox alignment="TOP_CENTER" prefWidth="250.0" spacing="15.0" style="-fx-background-color: #bdc3c7;" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <Label text="Place Bets" />
            <TextField fx:id="anteBetField" promptText="Ante Bet ($5 - $25)" />
            <TextField fx:id="pairPlusBetField" promptText="Pair Plus (Optional)" />
            
            <!-- Betting Area container to hide/show -->
            <VBox fx:id="bettingArea" alignment="CENTER" spacing="10.0">
                <Button fx:id="dealButton" maxWidth="1.7976931348623157E308" onAction="#handleDeal" style="-fx-background-color: #2980b9; -fx-text-fill: white;" text="DEAL" />
            </VBox>
            
            <!-- Play/Fold Area container -->
            <VBox fx:id="playFoldArea" alignment="CENTER" spacing="10.0">
                <Button fx:id="playButton" maxWidth="1.7976931348623157E308" onAction="#handlePlay" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="PLAY (Match Ante)" />
                <Button fx:id="foldButton" maxWidth="1.7976931348623157E308" onAction="#handleFold" style="-fx-background-color: #c0392b; -fx-text-fill: white;" text="FOLD" />
            </VBox>
            
            <Label text="Current Wagers:" underline="true" />
            <Label fx:id="anteWagerLabel" text="Ante: $0" />
            <Label fx:id="pairPlusWagerLabel" text="Pair Plus: $0" />
            <Label fx:id="playWagerLabel" text="Play: $0" />
         </children>
      </VBox>
   </right>
</BorderPane>